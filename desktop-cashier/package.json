{
  "name": "masterpiece-pos-cashier-desktop",
  "version": "1.0.52",
  "private": true,
  "description": "Desktop shell for Aurent cashier (same UI as web)",
  "main": "electron/main.cjs",
  "author": "Aurent",
  "scripts": {
    "start": "POS_REMOTE_UI=1 POS_CASHIER_URL=http://localhost:5173 electron .",
    "start:dev": "POS_REMOTE_UI=1 POS_CASHIER_URL=http://localhost:5173 electron .",
    "dev": "POS_EMBEDDED=1 electron .",
    "postinstall": "node scripts/rebuild-native-printer.cjs",
    "rebuild:native": "node scripts/rebuild-native-printer.cjs --required",
    "dist": "electron-builder --config electron-builder.config.cjs",
    "dist:mac": "electron-builder --mac --config electron-builder.config.cjs --publish never",
    "dist:win": "node scripts/rebuild-native-printer.cjs --required && electron-builder --win --config electron-builder.config.cjs --publish never --config.win.signAndEditExecutable=false --config.win.verifyUpdateCodeSignature=false",
    "dist:win:dir": "node scripts/rebuild-native-printer.cjs --required && electron-builder --win dir --config electron-builder.config.cjs --publish never --config.win.signAndEditExecutable=false",
    "test:print": "node scripts/test-print-logic.cjs",
    "test:escpos": "node scripts/test-escpos-build.cjs",
    "verify:win-unpacked": "node scripts/verify-windows-unpacked.cjs"
  },
  "build": {
    "appId": "com.aurent.pos.cashier",
    "productName": "Aurent Cashier",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "config.default.json",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.business",
      "artifactName": "Aurent-Cashier-${version}-mac-universal.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Aurent-Cashier-Setup-${version}-${arch}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "Aurent Cashier",
      "unicode": true,
      "installerLanguages": [
        "ru_RU",
        "en_US"
      ],
      "language": "1049",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "iconv-lite": "^0.6.3",
    "node-thermal-printer": "^4.6.0"
  },
  "optionalDependencies": {
    "@thiagoelg/node-printer": "^0.6.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
