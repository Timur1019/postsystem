# =============================================================================
# Aurent POS — production (.env на сервере: cp .env.example .env)
# =============================================================================

COMPOSE_PROJECT_NAME=aurent-pos

# --- PostgreSQL (только внутри Docker-сети) ---
POSTGRES_DB=pos_db
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Backend ---
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_long
# CORS: касса (Electron) и браузеры в LAN; при необходимости добавьте IP сервера
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://*:*,https://*:*

# --- Порты на хосте Ubuntu ---
HTTP_PORT=80
API_PORT=8080

# --- Часовой пояс ---
TZ=Asia/Tashkent

# --- Поддержка (сборка фронтенда, ARG в docker-compose) ---
VITE_SUPPORT_PHONE=+998 90 123 45 67
VITE_SUPPORT_TELEGRAM_BOT=your_support_bot

# --- ИИ-ассистент (DeepSeek) ---
AI_ASSISTANT_ENABLED=true
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_MODEL=deepseek-chat
AI_ASSISTANT_BASE_URL=https://api.deepseek.com

# --- Telegram-бот поддержки (telegram-support-bot/, отдельный процесс) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_GROUP_ID=
