# =============================================================================
# Aurent POS — production (.env на сервере: cp .env.example .env)
# =============================================================================

COMPOSE_PROJECT_NAME=aurent-pos

# --- PostgreSQL (только внутри Docker-сети) ---
POSTGRES_DB=pos_db
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Finance microservice (finance_db + finance-service) ---
FINANCE_DB_NAME=finance_db
FINANCE_DB_USER=finance_user
FINANCE_DB_PASSWORD=CHANGE_ME_finance_db_password
FINANCE_INTERNAL_API_KEY=CHANGE_ME_finance_internal_api_key
FINANCE_SERVICE_ENABLED=true

# --- Backend ---
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_long
# Пул БД и Tomcat (VPS 4 vCPU / 8 GB RAM — значения по умолчанию в docker-compose.prod.yml)
# HIKARI_MAX_POOL_SIZE=25
# HIKARI_MIN_IDLE=8
# TOMCAT_MAX_THREADS=100
# Swagger на prod по умолчанию выключен. Только для отладки на сервере:
# SPRINGDOC_SWAGGER_UI_ENABLED=true
# SPRINGDOC_API_DOCS_ENABLED=true
# CORS: касса (Electron) и браузеры в LAN; при необходимости добавьте IP сервера
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://*:*,https://*:*

# --- Порты на хосте Ubuntu ---
HTTP_PORT=80
API_PORT=8080

# --- Часовой пояс ---
TZ=Asia/Tashkent

# --- Поддержка (сборка фронтенда, ARG в docker-compose) ---
VITE_SUPPORT_PHONE="+998 90 123 45 67"
VITE_SUPPORT_TELEGRAM_BOT=your_support_bot

# --- ИИ-ассистент (DeepSeek) ---
AI_ASSISTANT_ENABLED=true
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_MODEL=deepseek-chat
AI_ASSISTANT_FAST_MODE=true
AI_ASSISTANT_BASE_URL=https://api.deepseek.com

# --- Email (Gmail SMTP / App Password) ---
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your@gmail.com
MAIL_FROM_NAME="Aurent POS"
MAIL_LOGIN_URL=https://your-domain/login?admin=1
MAIL_SUPER_ADMIN_LOGIN_RECIPIENTS=admin1@gmail.com,admin2@gmail.com
MAIL_SEND_CREDENTIALS_ON_CREATE=true

# --- Telegram-бот поддержки (telegram-support-bot/, отдельный процесс) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_GROUP_ID=
