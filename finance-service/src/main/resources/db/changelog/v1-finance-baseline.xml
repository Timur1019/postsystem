<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="finance-001-accounts" author="pos">
        <createTable tableName="financial_accounts">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="store_id" type="INT"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="DECIMAL(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(8)" defaultValue="UZS">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="UUID"/>
        </createTable>
        <createIndex tableName="financial_accounts" indexName="idx_fin_accounts_company">
            <column name="company_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="finance-002-categories" author="pos">
        <createTable tableName="income_categories">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(32)" defaultValue="INCOME">
                <constraints nullable="false"/>
            </column>
            <column name="is_system" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <createTable tableName="expense_categories">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(32)" defaultValue="EXPENSE">
                <constraints nullable="false"/>
            </column>
            <column name="is_system" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <changeSet id="finance-003-incomes" author="pos">
        <createTable tableName="incomes">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="store_id" type="INT"/>
            <column name="account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(8)" defaultValue="UZS">
                <constraints nullable="false"/>
            </column>
            <column name="payment_method" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="income_category_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="source_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="source_id" type="VARCHAR(64)"/>
            <column name="comment" type="VARCHAR(1000)"/>
            <column name="transaction_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="incomes" baseColumnNames="account_id"
                                 referencedTableName="financial_accounts" referencedColumnNames="id"
                                 constraintName="fk_incomes_account"/>
        <addForeignKeyConstraint baseTableName="incomes" baseColumnNames="income_category_id"
                                 referencedTableName="income_categories" referencedColumnNames="id"
                                 constraintName="fk_incomes_category"/>
        <createIndex tableName="incomes" indexName="idx_incomes_company_date">
            <column name="company_id"/>
            <column name="transaction_date"/>
        </createIndex>
        <createIndex tableName="incomes" indexName="idx_incomes_source">
            <column name="source_type"/>
            <column name="source_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="finance-004-expenses" author="pos">
        <createTable tableName="expenses">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="store_id" type="INT"/>
            <column name="account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(8)" defaultValue="UZS">
                <constraints nullable="false"/>
            </column>
            <column name="payment_method" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="expense_category_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="supplier_id" type="UUID"/>
            <column name="employee_id" type="UUID"/>
            <column name="source_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="source_id" type="VARCHAR(64)"/>
            <column name="comment" type="VARCHAR(1000)"/>
            <column name="transaction_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="UUID"/>
            <column name="updated_by" type="UUID"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="expenses" baseColumnNames="account_id"
                                 referencedTableName="financial_accounts" referencedColumnNames="id"
                                 constraintName="fk_expenses_account"/>
        <addForeignKeyConstraint baseTableName="expenses" baseColumnNames="expense_category_id"
                                 referencedTableName="expense_categories" referencedColumnNames="id"
                                 constraintName="fk_expenses_category"/>
        <createIndex tableName="expenses" indexName="idx_expenses_company_date">
            <column name="company_id"/>
            <column name="transaction_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="finance-005-company-bootstrap" author="pos">
        <createTable tableName="company_finance_bootstrap">
            <column name="company_id" type="INT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="bootstrapped_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
