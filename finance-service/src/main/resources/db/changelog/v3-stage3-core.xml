<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="finance-010-account-transfers" author="pos">
        <createTable tableName="account_transfers">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="store_id" type="INT"/>
            <column name="from_account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="from_account_name" type="VARCHAR(255)"/>
            <column name="to_account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="to_account_name" type="VARCHAR(255)"/>
            <column name="amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(8)">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="VARCHAR(1000)"/>
            <column name="transaction_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="UUID"/>
        </createTable>
        <createIndex tableName="account_transfers" indexName="idx_acc_transfer_company_date">
            <column name="company_id"/>
            <column name="transaction_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="finance-011-audit-log" author="pos">
        <createTable tableName="finance_audit_logs">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="UUID"/>
            <column name="action" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="summary" type="VARCHAR(500)"/>
            <column name="details" type="TEXT"/>
            <column name="actor_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="finance_audit_logs" indexName="idx_fin_audit_company_created">
            <column name="company_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
