# Опционально: nginx на хосте Ubuntu (SSL + прокси на Docker frontend :80).
# Установка: apt install nginx certbot python3-certbot-nginx
# Файл: /etc/nginx/sites-available/aurent-pos
# Ссылка: ln -s .../aurent-pos /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name pos.example.uz;

    client_max_body_size 80m;

    location / {
        proxy_pass http://127.0.0.1:80;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# После certbot:
