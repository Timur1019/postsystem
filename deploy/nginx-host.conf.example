#     listen 443 ssl http2;
#     server_name pos.example.uz;
#     ssl_certificate /etc/letsencrypt/live/pos.example.uz/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/pos.example.uz/privkey.pem;
#     ...
# }
